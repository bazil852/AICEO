PORT=8080

# Shared Supabase instance (same as AICEO)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Recall.ai
RECALL_API_KEY=your-recall-api-key
RECALL_REGION=us-west-2
RECALL_WEBHOOK_SECRET=your-svix-webhook-secret

# AI Processing (xAI Grok via OpenAI SDK)
XAI_API_KEY=your-xai-api-key

# This service's public URL (set by Railway)
API_BASE_URL=https://your-service.up.railway.app

# Google Calendar OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
